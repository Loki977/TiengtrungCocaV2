  "lessonText": [
    {
      "speaker": "旁白:",
      "chinese": "今天，Cam 和 Coca 打算开一家小咖啡店。",
      "pinyin": "Jīntiān, Cam hé Coca dǎsuàn kāi yì jiā xiǎo kāfēi diàn.",
      "vietnamese": "Hôm nay, Cam và Coca định mở một quán cà phê nhỏ.",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "我觉得店里应该放古典音乐，比较安静。",
      "pinyin": "Wǒ juéde diàn lǐ yīnggāi fàng gǔdiǎn yīnyuè, bǐjiào ānjìng.",
      "vietnamese": "Tôi nghĩ trong quán nên mở nhạc cổ điển, khá yên tĩnh.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "不行，年轻人更喜欢流行歌曲。",
      "pinyin": "Bù xíng, niánqīng rén gèng xǐhuan liúxíng gēqǔ.",
      "vietnamese": "Không được, người trẻ thích nhạc thịnh hành hơn.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "可是古典音乐比流行音乐安静得多。",
      "pinyin": "Kěshì gǔdiǎn yīnyuè bǐ liúxíng yīnyuè ānjìng de duō.",
      "vietnamese": "Nhưng nhạc cổ điển yên tĩnh hơn nhạc thịnh hành nhiều.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "怎么说呢？流行歌曲的歌词也有些写得很好。",
      "pinyin": "Zěnme shuō ne? Liúxíng gēqǔ de gēcí yě yǒuxiē xiě de hěn hǎo.",
      "vietnamese": "Nói thế nào nhỉ? Lời của một số ca khúc thịnh hành cũng viết rất hay.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "那我们放民歌吧，听起来比你我的意见都更安全。",
      "pinyin": "Nà wǒmen fàng míngē ba, tīng qǐlái bǐ nǐ wǒ de yìjiàn dōu gèng ānquán.",
      "vietnamese": "Vậy mở dân ca đi, nghe có vẻ an toàn hơn ý kiến của cả hai.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "客人:",
      "chinese": "你们先别吵，咖啡比音乐重要。",
      "pinyin": "Nǐmen xiān bié chǎo, kāfēi bǐ yīnyuè zhòngyào.",
      "vietnamese": "Hai người khoan cãi đã, cà phê quan trọng hơn âm nhạc.",
      "audio": "dialogue/007.mp3"
    }
  ],
  "story": [
    {
      "title": "Truyện vui: Quán cà phê chưa có cà phê",
      "chinese": "Cam 和 Coca 讨论了一个小时音乐，可是他们忘了买咖啡机。客人说：你们的音乐不错，可是我能喝一杯水吗？",
      "pinyin": "Cam hé Coca tǎolùn le yí ge xiǎoshí yīnyuè, kěshì tāmen wàng le mǎi kāfēi jī. Kèrén shuō: Nǐmen de yīnyuè búcuò, kěshì wǒ néng hē yì bēi shuǐ ma?",
      "vietnamese": "Cam và Coca bàn nhạc một tiếng nhưng quên mua máy pha cà phê. Khách nói: Nhạc hay đấy, nhưng tôi uống một cốc nước được không?"
    }
  ],
