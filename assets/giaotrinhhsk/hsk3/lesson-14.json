  "grammar": [
    {
      "title": "被动意义的表达：“被”字句 - Câu chữ 被 biểu thị bị động",
      "source": "PDF Giáo trình Hán ngữ 4 - Bài 14",
      "pattern": "主语 + 被（叫 / 让）+ 宾语 + 动词 + 其他成分",
      "structure": "Chủ ngữ + 被/叫/让 + tác nhân + động từ + thành phần khác",
      "explanation": "“被”字句用来表示被动意义。介词“被”及其宾语作状语，说明主语受到某个动作的影响。口语中常用“叫”“让”代替“被”；如果不强调施事者，“被”的宾语可以省略。",
      "examples": [
        "我的钱包被小偷偷走了。"
      ],
      "wrongExamples": [
        "* 我的钱包被小偷偷。",
        "* 还好，骨头被车没有撞伤了。"
      ],
      "usage": "Dùng khi muốn nói chủ ngữ chịu tác động của một hành động, thường là chuyện không mong muốn như 被撞伤、被偷走、被淋湿、被罚。"
    },
    {
      "title": "副词“又” - Phó từ 又 nhấn mạnh ngữ khí phủ định",
      "source": "PDF Giáo trình Hán ngữ 4 - Bài 14",
      "pattern": "又 + 不是 / 没 + ……",
      "structure": "又 + phủ định / câu phủ định",
      "explanation": "副词“又”可以加强否定语气，表示 người nói muốn nhấn mạnh rằng điều đó không phải như đối phương nghĩ hoặc không đáng để trách. Trong bài, 又 thường xuất hiện trong câu phủ định như “你又不是故意的”。",
      "examples": [
        "你又不是故意的。"
      ],
      "wrongExamples": [
        "* 你不是又故意的。"
      ],
      "usage": "Dùng để làm câu phủ định tự nhiên hơn, thường mang sắc thái giải thích, an ủi hoặc phản bác nhẹ."
    }
  ],
