  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你去过北京吗？",
      "pinyin": "Nǐ qùguo Běijīng ma?",
      "vietnamese": "Bạn đã từng đi Bắc Kinh chưa?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "去过。我去年去过一次。",
      "pinyin": "Qùguo. Wǒ qùnián qùguo yí cì.",
      "vietnamese": "Từng đi rồi. Năm ngoái tôi đã đi một lần.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你坐飞机去的吗？",
      "pinyin": "Nǐ zuò fēijī qù de ma?",
      "vietnamese": "Bạn đi bằng máy bay à?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "不是，我坐火车去的。",
      "pinyin": "Bú shì, wǒ zuò huǒchē qù de.",
      "vietnamese": "Không phải, tôi đi bằng tàu hỏa.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "北京怎么样？",
      "pinyin": "Běijīng zěnmeyàng?",
      "vietnamese": "Bắc Kinh thế nào?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "北京很漂亮。我们在长城拍了很多照片。",
      "pinyin": "Běijīng hěn piàoliang. Wǒmen zài Chángchéng pāi le hěn duō zhàopiàn.",
      "vietnamese": "Bắc Kinh rất đẹp. Chúng tôi đã chụp rất nhiều ảnh ở Vạn Lý Trường Thành.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Kinh nghiệm với 过",
      "pattern": "S + V + 过 + O",
      "structure": "S + V + 过 + O",
      "explanation": "Dùng để nói đã từng có kinh nghiệm làm việc gì.",
      "examples": [
        "我去过北京。Tôi đã từng đi Bắc Kinh.",
        "你吃过中国菜吗？Bạn đã từng ăn món Trung Quốc chưa?"
      ]
    },
    {
      "title": "Nhấn mạnh cách thức với 是...的",
      "pattern": "S + 是 + cách thức/thời gian/địa điểm + V + 的",
      "structure": "S + 是 + cách thức/thời gian/địa điểm + V + 的",
      "explanation": "Dùng để nhấn mạnh một thông tin đã xảy ra: đi khi nào, ở đâu, bằng gì.",
      "examples": [
        "我是坐火车去的。Tôi đi bằng tàu hỏa.",
        "他是昨天来的。Anh ấy đến hôm qua."
      ]
    },
    {
      "title": "Bổ ngữ trạng thái với 得",
      "pattern": "V + 得 + tính từ",
      "structure": "V + 得 + tính từ",
      "explanation": "Dùng để đánh giá hành động làm như thế nào.",
      "examples": [
        "他说得很好。Anh ấy nói rất tốt.",
        "我们玩得很高兴。Chúng tôi chơi rất vui."
      ]
    }
  ],
