  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你吃饭了吗？",
      "pinyin": "Nǐ chī fàn le ma?",
      "vietnamese": "Bạn ăn cơm chưa?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我还没吃呢。",
      "pinyin": "Wǒ hái méi chī ne.",
      "vietnamese": "Tôi vẫn chưa ăn.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "我们一起去吃饭吧。",
      "pinyin": "Wǒmen yìqǐ qù chī fàn ba.",
      "vietnamese": "Chúng ta cùng đi ăn cơm nhé.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "好啊。你喜欢吃中国菜吗？",
      "pinyin": "Hǎo a. Nǐ xǐhuan chī Zhōngguó cài ma?",
      "vietnamese": "Được. Bạn thích ăn món Trung Quốc không?",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "喜欢，中国菜很好吃。",
      "pinyin": "Xǐhuan, Zhōngguó cài hěn hǎochī.",
      "vietnamese": "Thích, món Trung Quốc rất ngon.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "那我们去饭馆吧。",
      "pinyin": "Nà wǒmen qù fànguǎn ba.",
      "vietnamese": "Vậy chúng ta đi nhà hàng nhé.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Trợ từ 了 biểu thị hoàn thành",
      "pattern": "S + V + O + 了",
      "structure": "S + V + O + 了",
      "explanation": "Dùng để nói một hành động đã hoàn thành.",
      "examples": [
        "我吃饭了。Tôi ăn cơm rồi.",
        "他去了学校。Anh ấy đã đi đến trường."
      ]
    },
    {
      "title": "Phủ định với 没/没有",
      "pattern": "S + 没(有) + V",
      "structure": "S + 没(有) + V",
      "explanation": "Khi phủ định hành động đã xảy ra, dùng <span class='hl'>没/没有</span>, không dùng 不.",
      "examples": [
        "我没吃饭。Tôi chưa ăn cơm.",
        "他没有去银行。Anh ấy chưa đi ngân hàng."
      ]
    },
    {
      "title": "Câu rủ rê với 吧",
      "pattern": "Câu đề nghị + 吧",
      "structure": "Câu đề nghị + 吧",
      "explanation": "<span class='hl'>吧</span> làm câu đề nghị nhẹ nhàng hơn.",
      "examples": [
        "我们去吃饭吧。Chúng ta đi ăn nhé.",
        "你休息一会儿吧。Bạn nghỉ một lát đi."
      ]
    }
