  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你最近忙吗？",
      "pinyin": "Nǐ zuìjìn máng ma?",
      "vietnamese": "Dạo này bạn bận không?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "很忙，我正在准备考试。",
      "pinyin": "Hěn máng, wǒ zhèngzài zhǔnbèi kǎoshì.",
      "vietnamese": "Rất bận, tôi đang chuẩn bị thi.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你复习得怎么样？",
      "pinyin": "Nǐ fùxí de zěnmeyàng?",
      "vietnamese": "Bạn ôn tập thế nào rồi?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "听力有点儿难，阅读还可以。",
      "pinyin": "Tīnglì yǒudiǎnr nán, yuèdú hái kěyǐ.",
      "vietnamese": "Nghe hơi khó, đọc hiểu thì tạm ổn.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你应该多练习。",
      "pinyin": "Nǐ yīnggāi duō liànxí.",
      "vietnamese": "Bạn nên luyện tập nhiều hơn.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "对，我会努力学习。",
      "pinyin": "Duì, wǒ huì nǔlì xuéxí.",
      "vietnamese": "Đúng vậy, tôi sẽ cố gắng học.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
