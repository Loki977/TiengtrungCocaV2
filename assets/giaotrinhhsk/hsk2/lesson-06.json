  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "请问，银行在哪儿？",
      "pinyin": "Qǐngwèn, yínháng zài nǎr?",
      "vietnamese": "Xin hỏi, ngân hàng ở đâu?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "银行在学校旁边。",
      "pinyin": "Yínháng zài xuéxiào pángbiān.",
      "vietnamese": "Ngân hàng ở bên cạnh trường học.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "远吗？",
      "pinyin": "Yuǎn ma?",
      "vietnamese": "Có xa không?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "不远，往前走，然后向右走。",
      "pinyin": "Bù yuǎn, wǎng qián zǒu, ránhòu xiàng yòu zǒu.",
      "vietnamese": "Không xa, đi thẳng về phía trước, sau đó rẽ phải.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "谢谢。我想换人民币。",
      "pinyin": "Xièxie. Wǒ xiǎng huàn rénmínbì.",
      "vietnamese": "Cảm ơn. Tôi muốn đổi nhân dân tệ.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "好的，你想换多少？",
      "pinyin": "Hǎo de, nǐ xiǎng huàn duōshao?",
      "vietnamese": "Được, bạn muốn đổi bao nhiêu?",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Câu hỏi địa điểm với 在哪儿",
      "pattern": "Địa điểm / Người + 在哪儿？",
      "structure": "Địa điểm / Người + 在哪儿？",
      "explanation": "Dùng để hỏi ai/cái gì ở đâu.",
      "examples": [
        "银行在哪儿？Ngân hàng ở đâu？",
        "老师在哪儿？Thầy/cô ở đâu?"
      ]
    },
    {
      "title": "Diễn đạt vị trí với 在",
      "pattern": "A + 在 + địa điểm",
      "structure": "A + 在 + địa điểm",
      "explanation": "<span class='hl'>在</span> dùng để nói vị trí của người hoặc vật.",
      "examples": [
        "银行在学校旁边。Ngân hàng ở bên cạnh trường.",
        "我在银行。Tôi ở ngân hàng."
      ]
    },
    {
      "title": "Chỉ đường với 往/向",
      "pattern": "往/向 + phương hướng + 走",
      "structure": "往/向 + phương hướng + 走",
      "explanation": "Dùng để chỉ hướng đi. <span class='hl'>往前走</span> là đi thẳng về phía trước.",
      "examples": [
        "往前走。Đi thẳng.",
        "向右走。Rẽ/phía bên phải mà đi."
      ]
    }
  ],
