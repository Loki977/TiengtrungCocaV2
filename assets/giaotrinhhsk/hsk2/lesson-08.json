  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你在做什么呢？",
      "pinyin": "Nǐ zài zuò shénme ne?",
      "vietnamese": "Bạn đang làm gì vậy?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我正在学习汉语。",
      "pinyin": "Wǒ zhèngzài xuéxí Hànyǔ.",
      "vietnamese": "Tôi đang học tiếng Trung.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你每天都学习吗？",
      "pinyin": "Nǐ měitiān dōu xuéxí ma?",
      "vietnamese": "Ngày nào bạn cũng học à?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "是的。可是今天我很忙。",
      "pinyin": "Shì de. Kěshì jīntiān wǒ hěn máng.",
      "vietnamese": "Đúng vậy. Nhưng hôm nay tôi rất bận.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你一会儿做什么？",
      "pinyin": "Nǐ yíhuìr zuò shénme?",
      "vietnamese": "Lát nữa bạn làm gì?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我给朋友打电话。",
      "pinyin": "Wǒ gěi péngyou dǎ diànhuà.",
      "vietnamese": "Tôi gọi điện cho bạn.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Diễn tả đang làm với 在/正在",
      "pattern": "S + 在/正在 + V + O",
      "structure": "S + 在/正在 + V + O",
      "explanation": "Dùng để nói hành động đang diễn ra tại thời điểm nói.",
      "examples": [
        "我正在学习汉语。Tôi đang học tiếng Trung.",
        "他们在说话。Họ đang nói chuyện."
      ]
    },
    {
      "title": "Nhấn mạnh với 呢 ở cuối câu",
      "pattern": "Câu hỏi/ câu trần thuật + 呢",
      "structure": "Câu hỏi/ câu trần thuật + 呢",
      "explanation": "<span class='hl'>呢</span> làm câu mềm hơn, thường dùng khi hỏi hành động đang diễn ra.",
      "examples": [
        "你在做什么呢？Bạn đang làm gì vậy?",
        "他看书呢。Anh ấy đang đọc sách đấy."
      ]
    },
    {
      "title": "给 + ai + làm gì",
      "pattern": "给 + người + V + O",
      "structure": "给 + người + V + O",
      "explanation": "Dùng khi hành động hướng đến một người nào đó.",
      "examples": [
        "我给妈妈打电话。Tôi gọi điện cho mẹ.",
        "老师给我们介绍汉字。Thầy/cô giới thiệu chữ Hán cho chúng tôi."
      ]
    }
  ],
