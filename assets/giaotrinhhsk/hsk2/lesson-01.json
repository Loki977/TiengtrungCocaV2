  "lessonText": [
    {
      "speaker": "玛丽:",
      "chinese": "我现在去图书馆，你跟我一起去，好吗？",
      "pinyin": "Wǒ xiànzài qù túshūguǎn, nǐ gēn wǒ yìqǐ qù, hǎo ma?",
      "vietnamese": "Bây giờ tôi đi thư viện, bạn đi cùng tôi được không?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "麦克:",
      "chinese": "好，咱们走吧。你常去图书馆吗？",
      "pinyin": "Hǎo, zánmen zǒu ba. Nǐ cháng qù túshūguǎn ma?",
      "vietnamese": "Được, chúng ta đi thôi. Bạn thường đến thư viện không?",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "玛丽:",
      "chinese": "常去。我常借书，也常在那儿看书。你呢？",
      "pinyin": "Cháng qù. Wǒ cháng jiè shū, yě cháng zài nàr kàn shū. Nǐ ne?",
      "vietnamese": "Thường đi. Tôi thường mượn sách, cũng thường đọc sách ở đó. Còn bạn?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "麦克:",
      "chinese": "我也常去。有时候借书，有时候上网查资料，但不常在那儿看书。",
      "pinyin": "Wǒ yě cháng qù. Yǒu shíhou jiè shū, yǒu shíhou shàng wǎng chá zīliào, dàn bù cháng zài nàr kàn shū.",
      "vietnamese": "Tôi cũng thường đi. Có lúc mượn sách, có lúc lên mạng tra tài liệu, nhưng không thường đọc sách ở đó.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "玛丽:",
      "chinese": "你的宿舍安静吗？",
      "pinyin": "Nǐ de sùshè ānjìng ma?",
      "vietnamese": "Ký túc xá của bạn yên tĩnh không?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "麦克:",
      "chinese": "很安静。",
      "pinyin": "Hěn ānjìng.",
      "vietnamese": "Rất yên tĩnh.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "晚上你常做什么？",
      "pinyin": "Wǎnshang nǐ cháng zuò shénme?",
      "vietnamese": "Buổi tối bạn thường làm gì?",
      "audio": "dialogue/007.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "复习课文，预习生词，或者做练习。",
      "pinyin": "Fùxí kèwén, yùxí shēngcí, huòzhě zuò liànxí.",
      "vietnamese": "Ôn bài khóa, chuẩn bị từ mới hoặc làm bài tập.",
      "audio": "dialogue/008.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Đề nghị với ……，好吗？",
      "pattern": "Câu đề nghị + ，好吗？",
      "structure": "S + V/O + ，好吗？",
      "explanation": "Dùng <span class='hl'>好吗</span> ở cuối câu để hỏi ý kiến hoặc đề nghị một cách nhẹ nhàng.",
      "examples": [
        "你跟我一起去，<span class='hl'>好吗</span>？Bạn đi cùng tôi được không?",
        "晚上咱们看电影，<span class='hl'>好吗</span>？Tối chúng ta xem phim được không?"
      ]
    },
    {
      "title": "咱们 và 我们",
      "pattern": "咱们 = tôi + bạn/chúng ta cùng làm",
      "structure": "咱们 + V + 吧",
      "explanation": "<span class='hl'>咱们</span> thường bao gồm cả người nghe; <span class='hl'>我们</span> có thể bao gồm hoặc không bao gồm người nghe.",
      "examples": [
        "<span class='hl'>咱们</span>走吧。Chúng ta đi thôi.",
        "我们是中国学生。Chúng tôi là học sinh Trung Quốc."
      ]
    },
    {
      "title": "Trợ từ 吧",
      "pattern": "Câu đề nghị + 吧",
      "structure": "S + V/O + 吧",
      "explanation": "<span class='hl'>吧</span> đặt cuối câu để biểu thị đề nghị, thúc giục hoặc đồng ý.",
      "examples": [
        "咱们走<span class='hl'>吧</span>。Chúng ta đi thôi.",
        "好<span class='hl'>吧</span>。Được thôi."
      ]
    },
    {
      "title": "Từ chỉ thời gian làm trạng ngữ",
      "pattern": "Thời gian + S + V / S + thời gian + V",
      "structure": "晚上我复习课文。/ 我晚上复习课文。",
      "explanation": "Từ chỉ thời gian thường đứng trước động từ hoặc trước chủ ngữ để nói thời điểm hành động xảy ra.",
      "examples": [
        "<span class='hl'>晚上</span>你常做什么？Buổi tối bạn thường làm gì?",
        "我<span class='hl'>有时候</span>上网查资料。Tôi thỉnh thoảng lên mạng tra tài liệu."
      ]
    },
    {
      "title": "还是 và 或者",
      "pattern": "A 还是 B？ / A 或者 B",
      "structure": "Câu hỏi dùng 还是; câu trần thuật dùng 或者",
      "explanation": "<span class='hl'>还是</span> dùng trong câu hỏi lựa chọn, còn <span class='hl'>或者</span> dùng trong câu kể để nói 'hoặc'.",
      "examples": [
        "你喝茶<span class='hl'>还是</span>喝咖啡？Bạn uống trà hay cà phê?",
        "我晚上复习课文<span class='hl'>或者</span>做练习。Tối tôi ôn bài hoặc làm bài tập."
      ]
    }
  ],
