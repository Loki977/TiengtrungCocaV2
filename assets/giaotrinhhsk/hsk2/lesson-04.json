  "lessonText": [
    {
      "speaker": "顾客:",
      "chinese": "这件衣服可以试试吗？",
      "pinyin": "Zhè jiàn yīfu kěyǐ shìshi ma?",
      "vietnamese": "Bộ quần áo này có thể thử được không?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "售货员:",
      "chinese": "可以。",
      "pinyin": "Kěyǐ.",
      "vietnamese": "Được.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "顾客:",
      "chinese": "多少钱？",
      "pinyin": "Duōshao qián?",
      "vietnamese": "Bao nhiêu tiền?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "售货员:",
      "chinese": "八十块。",
      "pinyin": "Bāshí kuài.",
      "vietnamese": "80 tệ.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "顾客:",
      "chinese": "太贵了，便宜一点儿吧。",
      "pinyin": "Tài guì le, piányi yìdiǎnr ba.",
      "vietnamese": "Đắt quá, rẻ hơn một chút đi.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "售货员:",
      "chinese": "七十五块，怎么样？",
      "pinyin": "Qīshíwǔ kuài, zěnmeyàng?",
      "vietnamese": "75 tệ, thế nào?",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "顾客:",
      "chinese": "还是太贵。",
      "pinyin": "Háishi tài guì.",
      "vietnamese": "Vẫn đắt quá.",
      "audio": "dialogue/007.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Động từ lặp lại",
      "pattern": "V + V / V一V",
      "structure": "试试 / 看看 / 想一想",
      "explanation": "Động từ lặp lại biểu thị thử làm nhẹ nhàng, trong thời gian ngắn.",
      "examples": [
        "这件衣服可以<span class='hl'>试试</span>吗？Bộ này có thể thử không?",
        "你<span class='hl'>看看</span>这本书。Bạn xem thử cuốn sách này đi."
      ]
    },
    {
      "title": "又……又……",
      "pattern": "又 + tính từ/động từ + 又 + tính từ/động từ",
      "structure": "又A又B",
      "explanation": "Dùng để nêu hai đặc điểm cùng tồn tại.",
      "examples": [
        "这件衣服<span class='hl'>又</span>好<span class='hl'>又</span>便宜。Bộ này vừa tốt vừa rẻ.",
        "他又会说汉语又会写汉字。Anh ấy vừa biết nói tiếng Trung vừa biết viết chữ Hán."
      ]
    },
    {
      "title": "一点儿 và 有一点儿",
      "pattern": "Adj + 一点儿 / 有一点儿 + Adj",
      "structure": "便宜一点儿 / 有一点儿贵",
      "explanation": "<span class='hl'>一点儿</span> thường dùng sau tính từ để yêu cầu giảm/tăng mức độ; <span class='hl'>有一点儿</span> đứng trước tính từ, thường mang sắc thái không hài lòng.",
      "examples": [
        "便宜<span class='hl'>一点儿</span>吧。Rẻ hơn một chút đi.",
        "这件衣服<span class='hl'>有一点儿</span>贵。Bộ này hơi đắt."
      ]
    }
