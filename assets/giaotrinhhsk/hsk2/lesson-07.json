  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "今天天气怎么样？",
      "pinyin": "Jīntiān tiānqì zěnmeyàng?",
      "vietnamese": "Thời tiết hôm nay thế nào?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "今天很热，也不下雨。",
      "pinyin": "Jīntiān hěn rè, yě bù xià yǔ.",
      "vietnamese": "Hôm nay rất nóng, cũng không mưa.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你喜欢夏天吗？",
      "pinyin": "Nǐ xǐhuan xiàtiān ma?",
      "vietnamese": "Bạn thích mùa hè không?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "不太喜欢。我喜欢秋天。",
      "pinyin": "Bù tài xǐhuan. Wǒ xǐhuan qiūtiān.",
      "vietnamese": "Không thích lắm. Tôi thích mùa thu.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "为什么？",
      "pinyin": "Wèishénme?",
      "vietnamese": "Tại sao?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "秋天不冷不热，很舒服。",
      "pinyin": "Qiūtiān bù lěng bù rè, hěn shūfu.",
      "vietnamese": "Mùa thu không lạnh không nóng, rất dễ chịu.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Hỏi tình hình với 怎么样",
      "pattern": "Chủ ngữ + 怎么样？",
      "structure": "Chủ ngữ + 怎么样？",
      "explanation": "Dùng để hỏi tình hình, trạng thái hoặc ý kiến về một việc.",
      "examples": [
        "今天天气怎么样？Thời tiết hôm nay thế nào?",
        "这件衣服怎么样？Bộ quần áo này thế nào?"
      ]
    },
    {
      "title": "Cấu trúc 不太 + tính từ/động từ",
      "pattern": "不太 + Adj/V",
      "structure": "不太 + Adj/V",
      "explanation": "Diễn đạt mức độ phủ định nhẹ: không lắm, không quá.",
      "examples": [
        "我不太喜欢夏天。Tôi không thích mùa hè lắm.",
        "今天不太冷。Hôm nay không lạnh lắm."
      ]
    },
    {
      "title": "Cấu trúc 不A不B",
      "pattern": "不 + tính từ 1 + 不 + tính từ 2",
      "structure": "不 + tính từ 1 + 不 + tính từ 2",
      "explanation": "Dùng để nói trạng thái ở giữa hai cực.",
      "examples": [
        "不冷不热。Không lạnh không nóng.",
        "不大不小。Không to không nhỏ."
      ]
    }
  ],
