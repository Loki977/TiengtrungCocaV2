  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你打算去哪儿旅游？",
      "pinyin": "Nǐ dǎsuàn qù nǎr lǚyóu?",
      "vietnamese": "Bạn dự định đi đâu du lịch?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我打算去上海。",
      "pinyin": "Wǒ dǎsuàn qù Shànghǎi.",
      "vietnamese": "Tôi dự định đi Thượng Hải.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你坐飞机还是坐火车？",
      "pinyin": "Nǐ zuò fēijī háishi zuò huǒchē?",
      "vietnamese": "Bạn đi máy bay hay tàu hỏa?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "飞机很快，但是票有点儿贵。",
      "pinyin": "Fēijī hěn kuài, dànshì piào yǒudiǎnr guì.",
      "vietnamese": "Máy bay nhanh, nhưng vé hơi đắt.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "坐火车也不错，行李也方便。",
      "pinyin": "Zuò huǒchē yě búcuò, xíngli yě fāngbiàn.",
      "vietnamese": "Đi tàu hỏa cũng khá tốt, hành lý cũng thuận tiện.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "那我选择坐火车去。",
      "pinyin": "Nà wǒ xuǎnzé zuò huǒchē qù.",
      "vietnamese": "Vậy tôi chọn đi bằng tàu hỏa.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "打算 + động từ",
      "pattern": "S + 打算 + V",
      "structure": "我打算去上海。",
      "explanation": "<span class='hl'>打算</span> dùng để nói dự định, kế hoạch gần hoặc xa.",
      "examples": [
        "你打算做什么？Bạn định làm gì?",
        "我打算明天出发。Tôi định xuất phát ngày mai."
      ]
    },
    {
      "title": "还是 trong câu hỏi lựa chọn",
      "pattern": "A 还是 B？",
      "structure": "坐飞机还是坐火车？",
      "explanation": "Dùng <span class='hl'>还是</span> để hỏi chọn một trong hai hoặc nhiều khả năng.",
      "examples": [
        "你喝茶还是喝咖啡？Bạn uống trà hay cà phê?",
        "今天去还是明天去？Đi hôm nay hay ngày mai?"
      ]
    },
    {
      "title": "比 để so sánh",
      "pattern": "A + 比 + B + Adj",
      "structure": "飞机比火车快。",
      "explanation": "Dùng <span class='hl'>比</span> để so sánh hơn/kém giữa hai sự vật.",
      "examples": [
        "飞机比火车快。Máy bay nhanh hơn tàu hỏa.",
        "今天比昨天冷。Hôm nay lạnh hơn hôm qua."
      ]
    }
  ],
