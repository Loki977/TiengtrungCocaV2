  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "我去邮局寄包裹。",
      "pinyin": "Wǒ qù yóujú jì bāoguǒ.",
      "vietnamese": "Tôi đi bưu điện gửi bưu phẩm.",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "顺便替我买几张邮票吧。",
      "pinyin": "Shùnbiàn tì wǒ mǎi jǐ zhāng yóupiào ba.",
      "vietnamese": "Tiện thể mua giúp tôi vài con tem nhé.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "没问题。",
      "pinyin": "Méi wèntí.",
      "vietnamese": "Không vấn đề gì.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "外留代表团明天去上海参观。",
      "pinyin": "Wàiliú dàibiǎotuán míngtiān qù Shànghǎi cānguān.",
      "vietnamese": "Đoàn đại biểu lưu học sinh nước ngoài ngày mai đi Thượng Hải tham quan.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "他们怎么去？",
      "pinyin": "Tāmen zěnme qù?",
      "vietnamese": "Họ đi bằng cách nào?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "坐火车去。",
      "pinyin": "Zuò huǒchē qù.",
      "vietnamese": "Đi bằng tàu hỏa.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Câu liên động",
      "pattern": "S + V1 + O1 + V2 + O2",
      "structure": "我去邮局寄包裹。",
      "explanation": "Câu có hai hoặc nhiều động từ liên tiếp, hành động trước thường là mục đích/điều kiện cho hành động sau.",
      "examples": [
        "我<span class='hl'>去邮局寄包裹</span>。Tôi đi bưu điện gửi bưu phẩm.",
        "他<span class='hl'>去上海参观</span>。Anh ấy đi Thượng Hải tham quan."
      ]
    },
    {
      "title": "顺便 + V",
      "pattern": "顺便 + làm việc gì",
      "structure": "顺便 + V + O",
      "explanation": "<span class='hl'>顺便</span> nghĩa là tiện thể, nhân tiện làm thêm việc gì đó.",
      "examples": [
        "顺便替我买几张邮票吧。Tiện thể mua giúp tôi vài con tem nhé.",
        "我去超市，顺便买水果。Tôi đi siêu thị, tiện thể mua hoa quả."
      ]
    },
    {
      "title": "没问题",
      "pattern": "Không vấn đề gì / được thôi",
      "structure": "没问题。",
      "explanation": "Dùng để đồng ý hoặc nói việc gì không khó, không sao.",
      "examples": [
        "A：你帮我买邮票，好吗？ B：<span class='hl'>没问题</span>。",
        "这个练习不难，没问题。"
      ]
    }
  ],
