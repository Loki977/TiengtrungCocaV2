  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你怎么了？",
      "pinyin": "Nǐ zěnme le?",
      "vietnamese": "Bạn bị sao vậy?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我有点儿不舒服，头很疼。",
      "pinyin": "Wǒ yǒudiǎnr bù shūfu, tóu hěn téng.",
      "vietnamese": "Tôi hơi không khỏe, đầu rất đau.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你发烧了吗？",
      "pinyin": "Nǐ fāshāo le ma?",
      "vietnamese": "Bạn sốt rồi à?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "可能感冒了。",
      "pinyin": "Kěnéng gǎnmào le.",
      "vietnamese": "Có thể tôi bị cảm rồi.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你应该去医院看看医生。",
      "pinyin": "Nǐ yīnggāi qù yīyuàn kànkan yīshēng.",
      "vietnamese": "Bạn nên đến bệnh viện khám bác sĩ.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "好，我先休息一下，多喝水。",
      "pinyin": "Hǎo, wǒ xiān xiūxi yíxià, duō hē shuǐ.",
      "vietnamese": "Được, tôi nghỉ một chút trước, uống nhiều nước.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "怎么了 hỏi tình trạng",
      "pattern": "S + 怎么了？",
      "structure": "你怎么了？",
      "explanation": "Dùng <span class='hl'>怎么了</span> để hỏi ai đó có chuyện gì, thường dùng khi thấy người kia không ổn.",
      "examples": [
        "你怎么了？Bạn bị sao vậy?",
        "他怎么了？Anh ấy bị sao vậy?"
      ]
    },
    {
      "title": "了 biểu thị thay đổi/tình trạng mới",
      "pattern": "V/Adj + 了",
      "structure": "我感冒了。",
      "explanation": "<span class='hl'>了</span> ở cuối câu có thể biểu thị một tình trạng mới xuất hiện.",
      "examples": [
        "我发烧了。Tôi sốt rồi.",
        "天气冷了。Trời lạnh rồi."
      ]
    },
    {
      "title": "应该 + động từ",
      "pattern": "S + 应该 + V",
      "structure": "你应该休息。",
      "explanation": "Dùng <span class='hl'>应该</span> để đưa lời khuyên hoặc nói điều nên làm.",
      "examples": [
        "你应该多喝水。Bạn nên uống nhiều nước.",
        "他应该去医院。Anh ấy nên đi bệnh viện."
      ]
    }
  ],
