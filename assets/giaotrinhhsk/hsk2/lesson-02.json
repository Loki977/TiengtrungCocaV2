  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "他在做什么呢？",
      "pinyin": "Tā zài zuò shénme ne?",
      "vietnamese": "Bạn ấy đang làm gì đấy?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "他正在学习汉字。",
      "pinyin": "Tā zhèngzài xuéxí Hànzì.",
      "vietnamese": "Bạn ấy đang học chữ Hán.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "谁教你们语法？",
      "pinyin": "Shéi jiāo nǐmen yǔfǎ?",
      "vietnamese": "Ai dạy ngữ pháp cho các bạn?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "王老师教我们语法。",
      "pinyin": "Wáng lǎoshī jiāo wǒmen yǔfǎ.",
      "vietnamese": "Thầy/cô Vương dạy chúng tôi ngữ pháp.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你准备口试吗？",
      "pinyin": "Nǐ zhǔnbèi kǒushì ma?",
      "vietnamese": "Bạn chuẩn bị thi nói chưa?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我正在准备。有问题我就问老师。",
      "pinyin": "Wǒ zhèngzài zhǔnbèi. Yǒu wèntí wǒ jiù wèn lǎoshī.",
      "vietnamese": "Tôi đang chuẩn bị. Có vấn đề thì tôi hỏi giáo viên.",
      "audio": "dialogue/006.mp3"
    }
  ],
