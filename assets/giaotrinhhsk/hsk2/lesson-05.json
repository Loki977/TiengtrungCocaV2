  "grammar": [
    {
      "title": "Câu vị ngữ danh từ",
      "pattern": "S + thời gian/tuổi/giá tiền",
      "structure": "今天星期一。/ 我二十岁。",
      "explanation": "Một số danh từ hoặc cụm danh từ có thể làm vị ngữ trực tiếp, thường nói ngày tháng, tuổi, giá tiền.",
      "examples": [
        "今天<span class='hl'>几月几号</span>？Hôm nay ngày mấy tháng mấy?",
        "我<span class='hl'>二零二四年大学毕业</span>。Tôi tốt nghiệp đại học năm 2024."
      ]
    },
    {
      "title": "Cách nói năm, tháng, ngày",
      "pattern": "年 + 月 + 日/号",
      "structure": "2024年8月10日",
      "explanation": "Thứ tự ngày tháng trong tiếng Trung là năm trước, rồi tháng, rồi ngày.",
      "examples": [
        "二零二四年八月十日。Ngày 10 tháng 8 năm 2024.",
        "你的生日是几月几号？Sinh nhật của bạn là ngày mấy tháng mấy?"
      ]
    },
    {
      "title": "怎么问：疑问语调",
      "pattern": "是吗？/ 真的吗？",
      "structure": "Câu + 吗？",
      "explanation": "Dùng ngữ điệu nghi vấn hoặc <span class='hl'>是吗</span> để hỏi lại, biểu thị ngạc nhiên hoặc xác nhận.",
      "examples": [
        "A：我明天去上海。B：<span class='hl'>是吗</span>？",
        "你大学毕业了，<span class='hl'>是吗</span>？"
      ]
    },
    {
      "title": "就在……",
      "pattern": "就 + 在 + nơi chốn",
      "structure": "S + 就在 + địa điểm",
      "explanation": "<span class='hl'>就</span> nhấn mạnh vị trí rất gần, rõ ràng hoặc đúng chính nơi đó.",
