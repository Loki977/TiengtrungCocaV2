  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你在哪儿学习？",
      "pinyin": "Nǐ zài nǎr xuéxí?",
      "vietnamese": "Bạn học ở đâu?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我在语言学院学习。",
      "pinyin": "Wǒ zài yǔyán xuéyuàn xuéxí.",
      "vietnamese": "Tôi học ở học viện ngôn ngữ.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你现在去哪儿？",
      "pinyin": "Nǐ xiànzài qù nǎr?",
      "vietnamese": "Bây giờ bạn đi đâu?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我去图书馆看书。",
      "pinyin": "Wǒ qù túshūguǎn kàn shū.",
      "vietnamese": "Tôi đi thư viện đọc sách.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "老师在教室吗？",
      "pinyin": "Lǎoshī zài jiàoshì ma?",
      "vietnamese": "Thầy/cô ở phòng học không?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "老师在教室里。",
      "pinyin": "Lǎoshī zài jiàoshì lǐ.",
      "vietnamese": "Thầy/cô ở trong phòng học.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "在 + nơi chốn + động từ",
      "pattern": "S + 在 + nơi chốn + V",
      "structure": "我在学校学习",
      "explanation": "Khi muốn nói làm việc gì ở đâu, đặt <span class='hl'>在 + nơi chốn</span> trước động từ.",
      "examples": [
        "我在图书馆看书。Tôi đọc sách ở thư viện.",
        "他在公司工作。Anh ấy làm việc ở công ty."
      ]
    },
    {
      "title": "哪儿 đặt tại vị trí cần hỏi",
      "pattern": "S + 在/去/住 + 哪儿？",
      "structure": "你在哪儿学习？",
      "explanation": "<span class='hl'>哪儿</span> không nhất thiết đứng đầu câu, mà đứng tại chỗ thông tin địa điểm cần hỏi.",
      "examples": [
        "你住哪儿？Bạn sống ở đâu?",
        "你在哪儿学习？Bạn học ở đâu?"
      ]
    },
    {
      "title": "里: bên trong",
      "pattern": "Nơi chốn + 里",
      "structure": "教室里",
      "explanation": "<span class='hl'>里</span> nghĩa là bên trong, dùng sau danh từ chỉ nơi chốn.",
      "examples": [
        "教室里有老师。Trong phòng học có thầy/cô.",
        "学校里有图书馆。Trong trường có thư viện."
      ]
    }
  ],
