  "grammar": [
    {
      "title": "有: có/sở hữu",
      "pattern": "S + 有 + N",
      "structure": "公司有职员",
      "explanation": "<span class='hl'>有</span> dùng để nói ai/cái gì có thứ gì, hoặc ở đâu có gì.",
      "examples": [
        "我有书。Tôi có sách.",
        "公司有很多职员。Công ty có nhiều nhân viên."
      ]
    },
    {
      "title": "没有: không có",
      "pattern": "S + 没有 + N",
      "structure": "我没有车",
      "explanation": "Phủ định của <span class='hl'>有</span> là <span class='hl'>没有</span>, không dùng 不有.",
      "examples": [
        "我没有车。Tôi không có xe.",
        "他没有汉语书。Anh ấy không có sách tiếng Hán."
      ]
    },
    {
      "title": "几 và 多少",
      "pattern": "几 + lượng từ + N / 多少 + N",
      "structure": "几口人 / 多少职员",
      "explanation": "<span class='hl'>几</span> thường hỏi số lượng nhỏ và cần lượng từ; <span class='hl'>多少</span> hỏi số lượng nói chung.",
      "examples": [
        "你家有几口人？Nhà bạn có mấy người?",
        "公司有多少职员？Công ty có bao nhiêu nhân viên?"
      ]
    },
    {
      "title": "口: lượng từ cho người trong gia đình",
      "pattern": "Số + 口 + 人",
      "structure": "三口人",
      "explanation": "Khi nói gia đình có mấy người, thường dùng lượng từ <span class='hl'>口</span>.",
      "examples": [
        "我家有三口人。Nhà tôi có ba người.",
        "他家有四口人。Nhà anh ấy có bốn người."
      ]
    }
