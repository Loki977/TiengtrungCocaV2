  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你在哪儿工作？",
      "pinyin": "Nǐ zài nǎr gōngzuò?",
      "vietnamese": "Bạn làm việc ở đâu?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我在公司工作。",
      "pinyin": "Wǒ zài gōngsī gōngzuò.",
      "vietnamese": "Tôi làm việc ở công ty.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你们公司有多少职员？",
      "pinyin": "Nǐmen gōngsī yǒu duōshao zhíyuán?",
      "vietnamese": "Công ty các bạn có bao nhiêu nhân viên?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我们公司有一百多个职员。",
      "pinyin": "Wǒmen gōngsī yǒu yì bǎi duō ge zhíyuán.",
      "vietnamese": "Công ty chúng tôi có hơn một trăm nhân viên.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你家有几口人？",
      "pinyin": "Nǐ jiā yǒu jǐ kǒu rén?",
      "vietnamese": "Nhà bạn có mấy người?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我家有三口人。",
      "pinyin": "Wǒ jiā yǒu sān kǒu rén.",
      "vietnamese": "Nhà tôi có ba người.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你有车吗？",
      "pinyin": "Nǐ yǒu chē ma?",
      "vietnamese": "Bạn có xe không?",
      "audio": "dialogue/007.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我没有车。",
      "pinyin": "Wǒ méiyǒu chē.",
      "vietnamese": "Tôi không có xe.",
      "audio": "dialogue/008.mp3"
    }
  ],
  "grammar": [
    {
      "title": "有: có/sở hữu",
      "pattern": "S + 有 + N",
      "structure": "公司有职员",
      "explanation": "<span class='hl'>有</span> dùng để nói ai/cái gì có thứ gì, hoặc ở đâu có gì.",
      "examples": [
        "我有书。Tôi có sách.",
        "公司有很多职员。Công ty có nhiều nhân viên."
      ]
    },
    {
      "title": "没有: không có",
      "pattern": "S + 没有 + N",
      "structure": "我没有车",
      "explanation": "Phủ định của <span class='hl'>有</span> là <span class='hl'>没有</span>, không dùng 不有.",
      "examples": [
        "我没有车。Tôi không có xe.",
        "他没有汉语书。Anh ấy không có sách tiếng Hán."
      ]
    },
    {
      "title": "几 và 多少",
      "pattern": "几 + lượng từ + N / 多少 + N",
      "structure": "几口人 / 多少职员",
      "explanation": "<span class='hl'>几</span> thường hỏi số lượng nhỏ và cần lượng từ; <span class='hl'>多少</span> hỏi số lượng nói chung.",
      "examples": [
        "你家有几口人？Nhà bạn có mấy người?",
        "公司有多少职员？Công ty có bao nhiêu nhân viên?"
      ]
    },
    {
      "title": "口: lượng từ cho người trong gia đình",
      "pattern": "Số + 口 + 人",
      "structure": "三口人",
      "explanation": "Khi nói gia đình có mấy người, thường dùng lượng từ <span class='hl'>口</span>.",
      "examples": [
        "我家有三口人。Nhà tôi có ba người.",
        "他家有四口人。Nhà anh ấy có bốn người."
      ]
    }
