  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你学习什么？",
      "pinyin": "Nǐ xuéxí shénme?",
      "vietnamese": "Bạn học gì?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我学习汉语。",
      "pinyin": "Wǒ xuéxí Hànyǔ.",
      "vietnamese": "Tôi học tiếng Hán.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你看什么书？",
      "pinyin": "Nǐ kàn shénme shū?",
      "vietnamese": "Bạn đọc sách gì?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我看汉语书。",
      "pinyin": "Wǒ kàn Hànyǔ shū.",
      "vietnamese": "Tôi đọc sách tiếng Hán.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你写汉字吗？",
      "pinyin": "Nǐ xiě Hànzì ma?",
      "vietnamese": "Bạn viết chữ Hán không?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我写汉字，也说汉语。",
      "pinyin": "Wǒ xiě Hànzì, yě shuō Hànyǔ.",
      "vietnamese": "Tôi viết chữ Hán, cũng nói tiếng Hán.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Động từ + tân ngữ",
      "pattern": "S + V + O",
      "structure": "我 + 学习 + 汉语",
      "explanation": "Trong tiếng Trung, động từ thường đứng trước tân ngữ. Câu <span class='hl'>我学习汉语</span> nghĩa là tôi học tiếng Hán.",
      "examples": [
        "我看书。Tôi đọc sách.",
        "我写汉字。Tôi viết chữ Hán."
      ]
    },
    {
      "title": "也: cũng",
      "pattern": "S + 也 + V/O/Adj",
      "structure": "我也学习汉语",
      "explanation": "<span class='hl'>也</span> đặt trước động từ hoặc tính từ để nói 'cũng'.",
      "examples": [
        "我也学习汉语。Tôi cũng học tiếng Hán.",
        "他也很好。Anh ấy cũng khỏe."
      ]
    },
    {
      "title": "都: đều",
      "pattern": "Chủ ngữ số nhiều + 都 + V/Adj",
      "structure": "我们都学习汉语",
      "explanation": "<span class='hl'>都</span> dùng khi nói tất cả những người/vật được nhắc đến đều như vậy.",
      "examples": [
        "我们都学习汉语。Chúng tôi đều học tiếng Hán.",
        "他们都很好。Họ đều khỏe."
      ]
    }
  ],
