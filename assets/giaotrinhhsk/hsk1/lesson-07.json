  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你吃什么？",
      "pinyin": "Nǐ chī shénme?",
      "vietnamese": "Bạn ăn gì?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我吃米饭。",
      "pinyin": "Wǒ chī mǐfàn.",
      "vietnamese": "Tôi ăn cơm.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你喝茶吗？",
      "pinyin": "Nǐ hē chá ma?",
      "vietnamese": "Bạn uống trà không?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我不喝茶，我喝开水。",
      "pinyin": "Wǒ bù hē chá, wǒ hē kāishuǐ.",
      "vietnamese": "Tôi không uống trà, tôi uống nước lọc.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你要什么？",
      "pinyin": "Nǐ yào shénme?",
      "vietnamese": "Bạn muốn gì?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我要饺子。",
      "pinyin": "Wǒ yào jiǎozi.",
      "vietnamese": "Tôi muốn sủi cảo.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Câu hỏi với 什么",
      "pattern": "S + V + 什么？",
      "structure": "你 + 吃 + 什么？",
      "explanation": "<span class='hl'>什么</span> dùng để hỏi 'gì/cái gì', thường đặt ở vị trí cần hỏi trong câu.",
      "examples": [
        "你吃什么？Bạn ăn gì?",
        "你学习什么？Bạn học gì?"
      ]
    },
    {
      "title": "Phủ định với 不",
      "pattern": "S + 不 + V/Adj",
      "structure": "我 + 不 + 喝茶",
      "explanation": "<span class='hl'>不</span> đứng trước động từ/tính từ để phủ định.",
      "examples": [
        "我不喝茶。Tôi không uống trà.",
        "汉语不难。Tiếng Hán không khó."
      ]
    },
    {
      "title": "要: muốn/cần",
      "pattern": "S + 要 + O",
      "structure": "我要米饭",
      "explanation": "<span class='hl'>要</span> dùng để nói muốn/cần một thứ gì đó.",
      "examples": [
        "我要米饭。Tôi muốn cơm.",
        "你要什么？Bạn muốn gì?"
      ]
    }
