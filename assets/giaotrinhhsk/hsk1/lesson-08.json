  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "苹果多少钱一斤？",
      "pinyin": "Píngguǒ duōshao qián yì jīn?",
      "vietnamese": "Táo bao nhiêu tiền một cân?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "三块五毛。",
      "pinyin": "Sān kuài wǔ máo.",
      "vietnamese": "Ba tệ năm hào.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "太贵了。",
      "pinyin": "Tài guì le.",
      "vietnamese": "Đắt quá.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "不贵，很便宜。",
      "pinyin": "Bú guì, hěn piányi.",
      "vietnamese": "Không đắt, rất rẻ.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "我买一斤。",
      "pinyin": "Wǒ mǎi yì jīn.",
      "vietnamese": "Tôi mua một cân.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "好，三块五毛。",
      "pinyin": "Hǎo, sān kuài wǔ máo.",
      "vietnamese": "Được, ba tệ năm hào.",
      "audio": "dialogue/006.mp3"
    }
  ],
