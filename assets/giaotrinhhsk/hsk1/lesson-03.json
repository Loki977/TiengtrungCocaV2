      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "谢谢老师。",
      "pinyin": "Xièxie lǎoshī.",
      "vietnamese": "Cảm ơn thầy/cô.",
      "audio": "dialogue/003.mp3"
    },
    {
