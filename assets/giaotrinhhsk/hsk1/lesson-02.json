    {
      "title": "Phủ định với 不",
      "pattern": "不 + tính từ / động từ",
      "structure": "S + 不 + Adj/V",
      "explanation": "Dùng <span class='hl'>不</span> để phủ định ở hiện tại hoặc thói quen. Khi đứng trước âm 4, <span class='hl'>不</span> thường đọc thành bú.",
      "examples": [
        "我<span class='hl'>不</span>忙。Tôi không bận.",
        "汉语<span class='hl'>不</span>难。Tiếng Hán không khó."
      ]
    },
    {
      "title": "Hỏi có/không với 吗",
      "pattern": "Câu khẳng định + 吗？",
      "structure": "S + Adj/V + 吗？",
      "explanation": "Đặt <span class='hl'>吗</span> cuối câu để hỏi dạng có/không.",
      "examples": [
        "你忙<span class='hl'>吗</span>？Bạn bận không?",
        "汉语难<span class='hl'>吗</span>？Tiếng Hán khó không?"
      ]
    },
    {
      "title": "Không quá... với 不太",
      "pattern": "不太 + tính từ",
      "structure": "S + 不太 + Adj",
      "explanation": "<span class='hl'>不太</span> nghĩa là không quá, không lắm; sắc thái nhẹ hơn 不.",
      "examples": [
