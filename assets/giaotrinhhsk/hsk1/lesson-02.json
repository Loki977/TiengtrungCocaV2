      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "汉语难吗？",
      "pinyin": "Hànyǔ nán ma?",
      "vietnamese": "Tiếng Hán khó không?",
      "audio": "dialogue/003.mp3"
    },
