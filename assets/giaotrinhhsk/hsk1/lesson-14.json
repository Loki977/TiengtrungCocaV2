  "grammar": [
    {
      "title": "的: biểu thị sở hữu",
      "pattern": "Người + 的 + vật",
      "structure": "我的车 / 你的书",
      "explanation": "<span class='hl'>的</span> đứng sau người sở hữu, tương đương 'của' trong tiếng Việt.",
      "examples": [
        "我的书。Sách của tôi.",
        "你的车。Xe của bạn."
      ]
    },
    {
      "title": "还是: câu hỏi lựa chọn",
      "pattern": "A + 还是 + B？",
      "structure": "新的还是旧的？",
      "explanation": "<span class='hl'>还是</span> dùng trong câu hỏi chọn một trong hai khả năng.",
      "examples": [
        "你喝茶还是开水？Bạn uống trà hay nước lọc?",
        "你的车是新的还是旧的？Xe của bạn mới hay cũ?"
      ]
    },
    {
      "title": "Lượng từ 本 / 辆",
      "pattern": "Số + lượng từ + danh từ",
      "structure": "一本书 / 一辆车",
      "explanation": "<span class='hl'>本</span> dùng cho sách, <span class='hl'>辆</span> dùng cho xe.",
      "examples": [
        "一本汉语书。Một quyển sách tiếng Hán.",
        "一辆新车。Một chiếc xe mới."
      ]
    }
