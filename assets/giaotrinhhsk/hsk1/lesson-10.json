  "grammar": [
    {
      "title": "Hỏi nơi ở với 哪儿",
      "pattern": "S + 住 + 哪儿？",
      "structure": "你住哪儿？",
      "explanation": "<span class='hl'>哪儿</span> nghĩa là 'đâu/ở đâu', đặt ở vị trí nơi chốn cần hỏi.",
      "examples": [
        "你住哪儿？Bạn sống ở đâu?",
        "他去哪儿？Anh ấy đi đâu?"
      ]
    },
    {
      "title": "在: ở/tại",
      "pattern": "S + 在 + nơi chốn",
      "structure": "我家在河内",
      "explanation": "<span class='hl'>在</span> dùng để nói vị trí hoặc nơi chốn.",
      "examples": [
        "我在学校。Tôi ở trường.",
        "我家在河内。Nhà tôi ở Hà Nội."
      ]
    },
    {
      "title": "们: số nhiều cho người",
      "pattern": "Đại từ/người + 们",
      "structure": "我 + 们 = 我们",
      "explanation": "<span class='hl'>们</span> thêm sau đại từ hoặc danh từ chỉ người để tạo nghĩa số nhiều.",
      "examples": [
        "我们学习汉语。Chúng tôi học tiếng Hán.",
        "他们都很好。Họ đều khỏe."
      ]
    }
  ],
