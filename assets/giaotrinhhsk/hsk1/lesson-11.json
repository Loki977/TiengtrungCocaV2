  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "你是哪国人？",
      "pinyin": "Nǐ shì nǎ guó rén?",
      "vietnamese": "Bạn là người nước nào?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我是越南人。你呢？",
      "pinyin": "Wǒ shì Yuènánrén. Nǐ ne?",
      "vietnamese": "Tôi là người Việt Nam. Còn bạn?",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "我是中国人。",
      "pinyin": "Wǒ shì Zhōngguórén.",
      "vietnamese": "Tôi là người Trung Quốc.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "他们也是中国人吗？",
      "pinyin": "Tāmen yě shì Zhōngguórén ma?",
      "vietnamese": "Họ cũng là người Trung Quốc à?",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "不是，他们都是留学生。",
      "pinyin": "Bú shì, tāmen dōu shì liúxuéshēng.",
      "vietnamese": "Không phải, họ đều là du học sinh.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我们也都是学生。",
      "pinyin": "Wǒmen yě dōu shì xuésheng.",
      "vietnamese": "Chúng tôi cũng đều là học sinh/sinh viên.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Hỏi quốc tịch với 哪国人",
      "pattern": "S + 是 + 哪国人？",
      "structure": "你是哪国人？",
      "explanation": "<span class='hl'>哪国人</span> dùng để hỏi một người đến từ quốc gia nào.",
      "examples": [
        "你是哪国人？Bạn là người nước nào?",
        "我是越南人。Tôi là người Việt Nam."
      ]
    },
    {
      "title": "Câu 是 + danh từ",
      "pattern": "S + 是 + N",
      "structure": "我是学生",
      "explanation": "<span class='hl'>是</span> dùng để giới thiệu, xác nhận danh tính, nghề nghiệp hoặc quốc tịch.",
      "examples": [
        "他是老师。Anh ấy là thầy giáo.",
        "她是中国人。Cô ấy là người Trung Quốc."
      ]
    },
    {
      "title": "也都: cũng đều",
      "pattern": "S + 也 + 都 + V/Adj/N",
      "structure": "我们也都是学生",
      "explanation": "Có thể kết hợp <span class='hl'>也</span> và <span class='hl'>都</span> để nói 'cũng đều'.",
      "examples": [
        "他们也都是留学生。Họ cũng đều là du học sinh.",
        "我们也都很好。Chúng tôi cũng đều khỏe."
      ]
    }
