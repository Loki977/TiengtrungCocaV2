  "grammar": [
    {
      "title": "Câu hỏi A 不 A",
      "pattern": "V/Adj + 不 + V/Adj？",
      "structure": "是不是 / 好不好",
      "explanation": "Ngoài 吗, tiếng Trung còn có dạng hỏi lặp <span class='hl'>A 不 A</span>, nghĩa là 'có...không'.",
      "examples": [
        "这是不是中药？Đây có phải thuốc Đông y không?",
        "你好不好？Bạn có khỏe không?"
      ]
    },
    {
      "title": "这 / 那: đây / kia",
      "pattern": "这/那 + 是 + N",
      "structure": "这是中药",
      "explanation": "<span class='hl'>这</span> là đây/cái này, <span class='hl'>那</span> là kia/cái đó.",
      "examples": [
        "这是书。Đây là sách.",
        "那是医院。Kia là bệnh viện."
      ]
    },
    {
      "title": "去 + nơi chốn + làm gì",
      "pattern": "S + 去 + nơi chốn + V/O",
      "structure": "我去医院看医生",
      "explanation": "Dùng <span class='hl'>去</span> trước nơi chốn để nói đi tới đâu làm việc gì.",
      "examples": [
        "我去图书馆看书。Tôi đi thư viện đọc sách.",
        "我去医院看医生。Tôi đi bệnh viện khám bác sĩ."
      ]
    }
