  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "这是什么？",
      "pinyin": "Zhè shì shénme?",
      "vietnamese": "Đây là cái gì?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "这是中药。",
      "pinyin": "Zhè shì zhōngyào.",
      "vietnamese": "Đây là thuốc Đông y.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "这是不是中药？",
      "pinyin": "Zhè shì bú shì zhōngyào?",
      "vietnamese": "Đây có phải là thuốc Đông y không?",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "是，这是中药。",
      "pinyin": "Shì, zhè shì zhōngyào.",
      "vietnamese": "Phải, đây là thuốc Đông y.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你生病了吗？",
      "pinyin": "Nǐ shēngbìng le ma?",
      "vietnamese": "Bạn bị ốm rồi à?",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我身体不太好。",
      "pinyin": "Wǒ shēntǐ bú tài hǎo.",
      "vietnamese": "Sức khỏe tôi không tốt lắm.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你去医院吗？",
      "pinyin": "Nǐ qù yīyuàn ma?",
      "vietnamese": "Bạn đi bệnh viện không?",
      "audio": "dialogue/007.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我去医院看医生。",
      "pinyin": "Wǒ qù yīyuàn kàn yīshēng.",
      "vietnamese": "Tôi đi bệnh viện khám bác sĩ.",
      "audio": "dialogue/008.mp3"
    }
  ],
  "grammar": [
    {
      "title": "Câu hỏi A 不 A",
      "pattern": "V/Adj + 不 + V/Adj？",
      "structure": "是不是 / 好不好",
      "explanation": "Ngoài 吗, tiếng Trung còn có dạng hỏi lặp <span class='hl'>A 不 A</span>, nghĩa là 'có...không'.",
      "examples": [
        "这是不是中药？Đây có phải thuốc Đông y không?",
        "你好不好？Bạn có khỏe không?"
      ]
    },
    {
      "title": "这 / 那: đây / kia",
      "pattern": "这/那 + 是 + N",
      "structure": "这是中药",
      "explanation": "<span class='hl'>这</span> là đây/cái này, <span class='hl'>那</span> là kia/cái đó.",
      "examples": [
        "这是书。Đây là sách.",
        "那是医院。Kia là bệnh viện."
      ]
    },
    {
      "title": "去 + nơi chốn + làm gì",
