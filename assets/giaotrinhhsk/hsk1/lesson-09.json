      "structure": "给我美元",
      "explanation": "<span class='hl'>给</span> dùng khi đưa hoặc cho ai thứ gì.",
      "examples": [
        "请给我书。Xin đưa tôi sách.",
        "给你。Đưa bạn đây."
      ]
    },
    {
      "title": "Số tiền với 百 / 千",
      "pattern": "Số + 百/千 + 块/美元",
      "structure": "一百美元 / 一千块",
      "explanation": "<span class='hl'>百</span> là trăm, <span class='hl'>千</span> là nghìn, dùng khi nói số lượng tiền.",
      "examples": [
        "一百美元。Một trăm đô la Mỹ.",
        "一千块钱。Một nghìn tệ."
      ]
    }
