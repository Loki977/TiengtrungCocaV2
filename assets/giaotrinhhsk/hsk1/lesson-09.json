  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "请问，我换人民币。",
      "pinyin": "Qǐngwèn, wǒ huàn rénmínbì.",
      "vietnamese": "Xin hỏi, tôi đổi nhân dân tệ.",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "你换多少？",
      "pinyin": "Nǐ huàn duōshao?",
      "vietnamese": "Bạn đổi bao nhiêu?",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "我换一百美元。",
      "pinyin": "Wǒ huàn yì bǎi měiyuán.",
      "vietnamese": "Tôi đổi một trăm đô la Mỹ.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "请给我美元。",
      "pinyin": "Qǐng gěi wǒ měiyuán.",
      "vietnamese": "Xin đưa tôi đô la Mỹ.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "给你。",
      "pinyin": "Gěi nǐ.",
      "vietnamese": "Đưa bạn đây.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "这是人民币。",
      "pinyin": "Zhè shì rénmínbì.",
      "vietnamese": "Đây là nhân dân tệ.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "谢谢！",
      "pinyin": "Xièxie!",
      "vietnamese": "Cảm ơn!",
      "audio": "dialogue/007.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "不客气。",
      "pinyin": "Bú kèqi.",
      "vietnamese": "Không có gì.",
      "audio": "dialogue/008.mp3"
    }
  ],
  "grammar": [
    {
      "title": "请问: xin hỏi",
      "pattern": "请问 + câu hỏi",
      "structure": "请问，你换多少？",
      "explanation": "<span class='hl'>请问</span> dùng lịch sự khi muốn hỏi thông tin.",
      "examples": [
        "请问，你叫什么名字？Xin hỏi, bạn tên là gì?",
