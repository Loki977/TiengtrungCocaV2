  "lessonText": [
    {
      "speaker": "A:",
      "chinese": "这是谁？",
      "pinyin": "Zhè shì shéi?",
      "vietnamese": "Đây là ai?",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "这是王老师。",
      "pinyin": "Zhè shì Wáng lǎoshī.",
      "vietnamese": "Đây là thầy/cô Vương.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "王老师，您好！",
      "pinyin": "Wáng lǎoshī, nín hǎo!",
      "vietnamese": "Thầy/cô Vương, em chào thầy/cô ạ!",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "你好！",
      "pinyin": "Nǐ hǎo!",
      "vietnamese": "Chào em!",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "认识你很高兴。",
      "pinyin": "Rènshi nǐ hěn gāoxìng.",
      "vietnamese": "Rất vui được quen bạn.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我也很高兴。",
      "pinyin": "Wǒ yě hěn gāoxìng.",
      "vietnamese": "Tôi cũng rất vui.",
      "audio": "dialogue/006.mp3"
    }
  ],
  "grammar": [
    {
