      "pattern": "这是 + người/vật",
      "structure": "这 + 是 + N",
      "explanation": "<span class='hl'>这是</span> nghĩa là đây là, dùng để giới thiệu người hoặc vật ở gần người nói.",
      "examples": [
        "<span class='hl'>这是</span>王老师。Đây là thầy/cô Vương.",
        "<span class='hl'>这是</span>我朋友。Đây là bạn tôi."
      ]
    },
    {
      "title": "Hỏi ai với 谁",
      "pattern": "S + 是 + 谁？",
      "structure": "这/那/他/她 + 是 + 谁",
      "explanation": "<span class='hl'>谁</span> dùng để hỏi người: ai.",
      "examples": [
        "这是谁？Đây là ai?",
        "他是谁？Anh ấy là ai?"
      ]
    },
