      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "B:",
      "chinese": "我不回家，我也去学校。",
      "pinyin": "Wǒ bù huí jiā, wǒ yě qù xuéxiào.",
      "vietnamese": "Tôi không về nhà, tôi cũng đi đến trường.",
      "audio": "dialogue/006.mp3"
    }
