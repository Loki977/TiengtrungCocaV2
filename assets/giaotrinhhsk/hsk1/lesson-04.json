    {
      "speaker": "B:",
      "chinese": "他去图书馆。",
      "pinyin": "Tā qù túshūguǎn.",
      "vietnamese": "Anh ấy đi thư viện.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "A:",
      "chinese": "你回家吗？",
      "pinyin": "Nǐ huí jiā ma?",
