  "lessonText": [
    {
      "speaker": "旁白:",
      "chinese": "在这一课里，我们通过“倾听的艺术”这个主题，讨论现代生活中常见却容易被忽略的问题。",
      "pinyin": "",
      "vietnamese": "Trong bài này, chúng ta thông qua chủ đề “倾听的艺术” để bàn về một vấn đề thường gặp nhưng dễ bị bỏ qua trong đời sống hiện đại.",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "我以前总觉得承担只是一个简单的词，可是经历多了以后，才发现它和挫折、趋势都有关系。",
      "pinyin": "",
      "vietnamese": "Trước đây tôi luôn nghĩ “承担” chỉ là một từ đơn giản, nhưng trải nghiệm nhiều rồi mới thấy nó liên quan đến 挫折 và 趋势.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "没错。尤其在面对效率的时候，一个人的沟通往往会影响最后的结果。",
      "pinyin": "",
      "vietnamese": "Đúng vậy. Đặc biệt khi đối mặt với 效率, 沟通 của một người thường ảnh hưởng đến kết quả cuối cùng.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "与其急着下结论，不如先观察事实，听听不同的声音，再形成自己的协调。",
      "pinyin": "",
      "vietnamese": "Thay vì vội kết luận, tốt hơn nên quan sát sự thật, lắng nghe nhiều tiếng nói khác nhau rồi hình thành 协调 của mình.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "即使过程不轻松，也能让我们学会角度，并且逐渐提高反思。",
      "pinyin": "",
      "vietnamese": "Cho dù quá trình không dễ dàng, nó vẫn giúp chúng ta học cách 角度 và dần nâng cao 反思.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "由此可见，真正重要的并非表面的成功，而是人在过程中积累的原则和立场。",
      "pinyin": "",
      "vietnamese": "Từ đó có thể thấy, điều thật sự quan trọng không phải thành công bề mặt, mà là 原则 và 立场 tích lũy trong quá trình.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "旁白:",
      "chinese": "这也是学习高级汉语的意义：用更准确的语言，表达更复杂的想法。",
      "pinyin": "",
      "vietnamese": "Đây cũng là ý nghĩa của việc học tiếng Trung nâng cao: dùng ngôn ngữ chính xác hơn để diễn đạt suy nghĩ phức tạp hơn.",
      "audio": "dialogue/007.mp3"
    }
  ],
  "story": [
    {
      "title": "Đọc mở rộng: Nghệ thuật lắng nghe",
      "chinese": "有一次，Cam 在准备一个关于“倾听的艺术”的分享。刚开始，他只想把资料堆在一起，后来发现，真正打动人的不是信息数量，而是清楚的逻辑和真实的体验。于是他重新整理例子，删掉空话，加入自己的观察。分享结束后，有同学说：“你讲的不是大道理，而是我们每天都会遇到的选择。”这句话让他意识到，高级表达并不是把句子说得复杂，而是把复杂的问题说清楚。",
      "pinyin": "",
      "vietnamese": "Một đoạn đọc mở rộng tự viết theo cùng chủ đề, dùng để luyện đọc hiểu và tóm tắt ở trình độ HSK6."
    }
  ],
  "culture": [
    {
      "title": "Góc văn hóa: 倾听的艺术",
      "content": "Ở trình độ HSK6, người học không chỉ ghi nhớ từ vựng mà còn cần hiểu cách người Trung Quốc trình bày quan điểm: thường đi từ hiện tượng, phân tích nguyên nhân, đưa ví dụ rồi rút ra kết luận. Khi học bài này, hãy chú ý các cụm nối ý như “由此可见”, “换句话说”, “从某种意义上说”."
    }
  ],
  "grammar": [
    {
      "title": "并非……而是……",
      "pattern": "并非……而是……",
      "structure": "并非 + phủ định hiểu lầm，而是 + bản chất",
      "explanation": "Dùng để sửa lại cách hiểu chưa chính xác.",
      "examples": [
        "自律并非限制自由，而是保护自由。",
        "失败并非终点，而是新的开始。"
      ]
    },
    {
      "title": "由此可见",
      "pattern": "由此可见",
      "structure": "由此可见 + kết luận",
      "explanation": "Dùng để rút ra kết luận từ ví dụ hoặc phân tích trước đó.",
      "examples": [
        "由此可见，细节体现态度。",
        "由此可见，信任需要长期积累。"
      ]
    },
    {
      "title": "不妨",
      "pattern": "不妨",
      "structure": "主语 + 不妨 + thử làm gì",
      "explanation": "Đưa ra lời khuyên mềm, nghĩa là “cứ thử”.",
      "examples": [
        "遇到困难时，你不妨换个角度。",
        "如果效率不高，不妨先整理计划。"
      ]
    },
    {
      "title": "与其……不如……",
      "pattern": "与其……不如……",
      "structure": "与其 + A，不如 + B",
      "explanation": "Dùng để so sánh hai lựa chọn, nhấn mạnh lựa chọn B hợp lý hơn.",
      "examples": [
        "与其一直抱怨，不如立刻行动。",
        "与其追求速度，不如保证质量。"
      ]
    },
    {
      "title": "即使……也……",
      "pattern": "即使……也……",
      "structure": "即使 + điều kiện giả định，也 + kết quả",
      "explanation": "Nhấn mạnh dù điều kiện bất lợi vẫn giữ kết quả/ý chí.",
      "examples": [
        "即使遇到挫折，也不要轻易放弃。",
        "即使意见不同，也可以好好沟通。"
      ]
    }
  ],
