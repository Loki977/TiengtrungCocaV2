      "title": "不仅……还……",
      "pattern": "不仅……还……",
      "structure": "不仅 + A，还 + B",
      "explanation": "Liên kết hai ý, ý sau thường bổ sung hoặc nâng cấp ý trước.",
      "examples": [
        "阅读不仅能积累知识，还能训练判断力。",
        "旅行不仅是放松，还是一种学习。"
      ]
    },
    {
      "title": "之所以……是因为……",
      "pattern": "之所以……是因为……",
      "structure": "之所以 + kết quả，是因为 + nguyên nhân",
      "explanation": "Dùng để giải thích nguyên nhân cốt lõi của một hiện tượng.",
      "examples": [
        "他之所以进步快，是因为方法正确。",
        "沟通之所以重要，是因为它能减少误会。"
      ]
    },
    {
      "title": "并非……而是……",
      "pattern": "并非……而是……",
      "structure": "并非 + phủ định hiểu lầm，而是 + bản chất",
      "explanation": "Dùng để sửa lại cách hiểu chưa chính xác.",
      "examples": [
        "自律并非限制自由，而是保护自由。",
        "失败并非终点，而是新的开始。"
      ]
    },
    {
      "title": "由此可见",
      "pattern": "由此可见",
      "structure": "由此可见 + kết luận",
      "explanation": "Dùng để rút ra kết luận từ ví dụ hoặc phân tích trước đó.",
      "examples": [
        "由此可见，细节体现态度。",
        "由此可见，信任需要长期积累。"
      ]
    }
  ],
