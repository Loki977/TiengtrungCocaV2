  "exerciseGroups": {
    "multiple-choice": [
      {
        "type": "multiple-choice",
        "question": "偏见 nghĩa là gì?",
        "options": [
          "định kiến",
          "bao dung",
          "cơ hội",
          "thách thức"
        ],
        "answer": "định kiến"
      },
      {
        "type": "multiple-choice",
        "question": "Cấu trúc nào diễn đạt “thay vì A, chi bằng B”?",
        "options": [
          "与其A，不如B",
          "虽然A，但是B",
          "因为A，所以B",
          "一边A，一边B"
        ],
        "answer": "与其A，不如B"
      }
    ],
    "fill-blank": [
      {
        "type": "fill-blank",
        "question": "Điền từ: ___一直抱怨，不如立刻行动。",
        "answer": "与其"
      },
      {
        "type": "fill-blank",
        "question": "Điền từ: ___遇到挫折，也不要轻易放弃。",
        "answer": "即使"
      }
    ],
    "sentence-order": [
      {
        "type": "sentence-order",
        "question": "Xếp câu: 不如 / 与其 / 行动 / 抱怨",
        "answer": "与其抱怨，不如行动"
      },
      {
        "type": "sentence-order",
        "question": "Xếp câu: 也 / 即使 / 坚持 / 失败",
        "answer": "即使失败，也坚持"
      }
    ],
