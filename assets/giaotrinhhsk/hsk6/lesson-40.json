  "lessonText": [
    {
      "speaker": "旁白:",
      "chinese": "在这一课里，我们通过“走得更远”这个主题，讨论现代生活中常见却容易被忽略的问题。",
      "pinyin": "",
      "vietnamese": "Trong bài này, chúng ta thông qua chủ đề “走得更远” để bàn về một vấn đề thường gặp nhưng dễ bị bỏ qua trong đời sống hiện đại.",
      "audio": "dialogue/001.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "我以前总觉得偏见只是一个简单的词，可是经历多了以后，才发现它和包容、机遇都有关系。",
      "pinyin": "",
      "vietnamese": "Trước đây tôi luôn nghĩ “偏见” chỉ là một từ đơn giản, nhưng trải nghiệm nhiều rồi mới thấy nó liên quan đến 包容 và 机遇.",
      "audio": "dialogue/002.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "没错。尤其在面对挑战的时候，一个人的危机往往会影响最后的结果。",
      "pinyin": "",
      "vietnamese": "Đúng vậy. Đặc biệt khi đối mặt với 挑战, 危机 của một người thường ảnh hưởng đến kết quả cuối cùng.",
      "audio": "dialogue/003.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "与其急着下结论，不如先观察事实，听听不同的声音，再形成自己的核心。",
      "pinyin": "",
      "vietnamese": "Thay vì vội kết luận, tốt hơn nên quan sát sự thật, lắng nghe nhiều tiếng nói khác nhau rồi hình thành 核心 của mình.",
      "audio": "dialogue/004.mp3"
    },
    {
      "speaker": "Coca:",
      "chinese": "即使过程不轻松，也能让我们学会边界，并且逐渐提高目标。",
      "pinyin": "",
      "vietnamese": "Cho dù quá trình không dễ dàng, nó vẫn giúp chúng ta học cách 边界 và dần nâng cao 目标.",
      "audio": "dialogue/005.mp3"
    },
    {
      "speaker": "Cam:",
      "chinese": "由此可见，真正重要的并非表面的成功，而是人在过程中积累的执行和反馈。",
      "pinyin": "",
      "vietnamese": "Từ đó có thể thấy, điều thật sự quan trọng không phải thành công bề mặt, mà là 执行 và 反馈 tích lũy trong quá trình.",
      "audio": "dialogue/006.mp3"
    },
    {
      "speaker": "旁白:",
      "chinese": "这也是学习高级汉语的意义：用更准确的语言，表达更复杂的想法。",
      "pinyin": "",
      "vietnamese": "Đây cũng là ý nghĩa của việc học tiếng Trung nâng cao: dùng ngôn ngữ chính xác hơn để diễn đạt suy nghĩ phức tạp hơn.",
      "audio": "dialogue/007.mp3"
    }
  ],
  "story": [
    {
      "title": "Đọc mở rộng: Tổng kết: đi xa hơn bằng tiếng Trung",
      "chinese": "有一次，Cam 在准备一个关于“走得更远”的分享。刚开始，他只想把资料堆在一起，后来发现，真正打动人的不是信息数量，而是清楚的逻辑和真实的体验。于是他重新整理例子，删掉空话，加入自己的观察。分享结束后，有同学说：“你讲的不是大道理，而是我们每天都会遇到的选择。”这句话让他意识到，高级表达并不是把句子说得复杂，而是把复杂的问题说清楚。",
      "pinyin": "",
      "vietnamese": "Một đoạn đọc mở rộng tự viết theo cùng chủ đề, dùng để luyện đọc hiểu và tóm tắt ở trình độ HSK6."
    }
  ],
  "culture": [
    {
      "title": "Góc văn hóa: 走得更远",
      "content": "Ở trình độ HSK6, người học không chỉ ghi nhớ từ vựng mà còn cần hiểu cách người Trung Quốc trình bày quan điểm: thường đi từ hiện tượng, phân tích nguyên nhân, đưa ví dụ rồi rút ra kết luận. Khi học bài này, hãy chú ý các cụm nối ý như “由此可见”, “换句话说”, “从某种意义上说”."
    }
  ],
  "grammar": [
    {
      "title": "与其……不如……",
      "pattern": "与其……不如……",
      "structure": "与其 + A，不如 + B",
      "explanation": "Dùng để so sánh hai lựa chọn, nhấn mạnh lựa chọn B hợp lý hơn.",
      "examples": [
